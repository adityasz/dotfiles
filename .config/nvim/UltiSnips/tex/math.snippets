context "math()"
snippet "\.T" "transpose" riA
^\top
endsnippet

priority 300
context "math()"
snippet dint "integral" w
\int_{${1:-\infty}}^{${2:\infty}} ${3:${VISUAL}} \,\symrm{d}${4:x}$0
endsnippet

