[delta]
    navigate = true
    hyperlinks = true
    hunk-label = ""
    hunk-header-file-style = ""
    hunk-header-line-number-style = ""
    hunk-header-style = "omit"
    hunk-header-decoration-style = "omit"
    file-decoration-style = none
    line-numbers = true
    line-numbers-left-format = "{nm:>4} ┊"
    line-numbers-right-format = "{np:>4} │"
